<Window x:Class="ESR_utils_App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="320" Width="500"
        Background="White" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" FontSize="13" LineHeight="20">
            <Run Text="This is an utility app for Eastern Sun Resurrected. It allows you to store appropriate items in their stockers. Once you press the assigned "/>
            <Run Text="&quot;Store hotkey&quot;" FontWeight="Bold"/>
            <Run Text=", the app will pick up the first stocker of each kind it finds and proceed to store all items that can fit inside. This can be customized by the checkboxes. "/>
            <Run Text="Your cube must be empty and inventory must be opened for the script to work." Foreground="Red" FontWeight="Bold"/>
            <Run Text="Optionally, the script also searches personal and all shared stash tabs of the current page if your stash is opened. You can"/>
            <Run Text="abort" Foreground="Red" FontWeight="Bold"/>
            <Run Text="the script by pressing the emergency stop hotkey."/>
        </TextBlock>

        <Button Grid.Row="1" Content="Close" Width="80" Height="28"
                HorizontalAlignment="Center" Margin="0,16,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>